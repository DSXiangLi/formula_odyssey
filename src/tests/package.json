{
  "name": "药灵山谷-AI测试",
  "version": "1.0.0",
  "description": "AI驱动的端到端测试系统",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:headed": "playwright test --headed",
    "test:report": "playwright show-report reports/playwright-report",
    "test:ai": "playwright test && node scripts/generate-ai-report.js",
    "test:visual": "playwright test --grep 'visual|动画'",
    "test:gameplay": "playwright test --grep '性味归经|方剂|临床'",
    "test:smoke": "playwright test --grep '登录|核心' --project=chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "typescript": "^5.3.0"
  }
}
